{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "test": "npm run test --workspace=frontend",
    "test:run": "npm run test:run --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "deploy:backend": "npm run deploy --workspace=backend",
    "deploy:frontend": "wrangler pages deploy frontend/dist"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
